# ─────────────────────────────────────────────────────────────────────────────
# Calculus Animator — environment configuration
#
# Copy this file to .env and fill in values you actually want set:
#     cp .env.example .env
#
# Every variable below is also documented at its read site:
#   - LLM_*  / *_API_KEY / FAST_MODEL / POWER_MODEL / VISION_MODEL
#       → ai_tutor/config.py
#   - CALCANIM_LOG_LEVEL
#       → ai_tutor/logging_config.py
#   - CALCANIM_MAX_REQUEST_BYTES
#       → ai_tutor/middleware.py
#   - CALC_ANIM_RENDER_*
#       → api/bridge.py
#   - CALCULUS_ANIMATOR_AUTO_INSTALL
#       → run.py
#
# All variables are optional; defaults are listed in the comments below.
# ─────────────────────────────────────────────────────────────────────────────


# ── AI Provider ──────────────────────────────────────────────────────────────
# Which LLM to use for the AI tutor.
# Options: deepseek | google | openai | anthropic | gemini_cli | local
# Default: "local" (auto-promoted to deepseek/google/gemini_cli at startup
# if the corresponding key/CLI is detected in the environment).
LLM_PROVIDER=deepseek

# ── API Keys (set the one matching your chosen provider) ─────────────────────
# Default: "" (provider unavailable when empty).
DEEPSEEK_API_KEY=your-deepseek-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Model overrides (optional) ───────────────────────────────────────────────
# Override the per-mode default model name. Defaults: "" (use provider default).
# FAST_MODEL=gemini-1.5-flash
# POWER_MODEL=gemini-1.5-pro
VISION_MODEL=gemini-2.0-flash


# ── Backend logging / hardening ──────────────────────────────────────────────
# Root logger level for the FastAPI tutor backend. Default: INFO.
# CALCANIM_LOG_LEVEL=INFO

# Max request body size in bytes for the local FastAPI backend. Requests
# beyond this are rejected with HTTP 413 + structured error envelope.
# Default: 10485760 (10 MiB).
# CALCANIM_MAX_REQUEST_BYTES=10485760


# ── Slide-render worker tuning (api/bridge.py) ───────────────────────────────
# Per-render budget in seconds for the persistent pygame worker. Default: 60.0.
# CALC_ANIM_RENDER_TIMEOUT_SEC=60.0

# Worker startup-deadline seconds; constructor blocks at most this long
# detecting an early-death import error. Default: 5.0.
# CALC_ANIM_RENDER_STARTUP_TIMEOUT_SEC=5.0

# Supervisor poll interval for crash detection. Default: 2.0.
# CALC_ANIM_RENDER_WATCHDOG_SEC=2.0


# ── Launcher convenience ─────────────────────────────────────────────────────
# Set to "1" to opt in to ``run.py`` auto-installing missing pip deps.
# Otherwise the launcher prints the missing-dep list and exits 1 instead of
# silently mutating the user's site-packages. Default: unset (do not auto-install).
# CALCULUS_ANIMATOR_AUTO_INSTALL=1
